/* 全局样式 */
/* 全局 box-sizing 修复 —— 防止 padding 撑大元素宽度 */
view, scroll-view, swiper, swiper-item, text, image, input, textarea, button, picker, form, label {
  box-sizing: border-box;
}

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
}

/* 通用容器 */
.container {
  min-height: 100vh;
}

/* 通用按钮样式 */
button {
  box-sizing: border-box;
}

button::after {
  border: none;
}

/* 通用输入框样式 */
input, textarea {
  box-sizing: border-box;
}

/* 通用图片样式 */
image {
  display: block;
}

/* 工具类 */
.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.align-center {
  align-items: center;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.p-20 {
  padding: 20rpx;
}

.p-30 {
  padding: 30rpx;
}

/* 响应式字体 */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }

/* 颜色类 */
.text-primary { color: #1296db; }
.text-success { color: #4caf50; }
.text-warning { color: #ff9800; }
.text-danger { color: #f44336; }
.text-gray { color: #666; }
.text-light { color: #999; }

.bg-primary { background-color: #1296db; }
.bg-success { background-color: #4caf50; }
.bg-warning { background-color: #ff9800; }
.bg-danger { background-color: #f44336; }
.bg-white { background-color: #fff; }
.bg-gray { background-color: #f8f9fa; }

/* 边框圆角 */
.rounded { border-radius: 8rpx; }
.rounded-lg { border-radius: 12rpx; }
.rounded-full { border-radius: 50%; }

/* 阴影 */
.shadow {
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.shadow-lg {
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

