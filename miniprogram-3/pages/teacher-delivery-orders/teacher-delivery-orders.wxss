.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

.header {
  background-color: #4caf50;
  padding: 30rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.tabs {
  background-color: #fff;
  white-space: nowrap;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 15rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f8f8f8;
  border-radius: 50rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #4caf50;
  color: #fff;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.order-status.pending {
  background-color: #fff3cd;
  color: #856404;
}

.order-status.delivered {
  background-color: #e8f5e9;
  color: #4caf50;
}

.order-info {
  margin-bottom: 20rpx;
}

.product-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.product-quantity {
  font-size: 24rpx;
  color: #999;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.info-label {
  color: #999;
  width: 150rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
}

.notes {
  background-color: #f8f8f8;
  padding: 15rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.notes-label {
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.notes-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
}

.deliver-btn {
  padding: 20rpx 40rpx;
  background-color: #4caf50;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
