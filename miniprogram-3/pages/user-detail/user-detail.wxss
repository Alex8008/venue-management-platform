.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.content {
  padding: 20rpx;
  box-sizing: border-box;
}

.section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.info-item {
  display: flex;
  margin-bottom: 25rpx;
  min-height: 50rpx;
}

.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-wrap: break-word;
}

.insurance-info {
  padding: 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.insurance-info.valid {
  background-color: #e8f5e8;
}

.insurance-info.invalid {
  background-color: #fff3cd;
}

.insurance-status {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.insurance-info.valid .insurance-status {
  color: #4caf50;
}

.insurance-info.invalid .insurance-status {
  color: #856404;
}

.insurance-period {
  font-size: 24rpx;
  color: #666;
}
.insurance-info.invalid {
  background-color: #fff3cd;
}

/* 新增：过期状态样式 */
.insurance-info.expired {
  background-color: #ffebee;
}

.insurance-info.expired .insurance-status {
  color: #f44336;
}

/* 新增：临时保险样式 */
.insurance-info.temporary {
  background-color: #e1f5fe;
}

.insurance-status {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.insurance-info.valid .insurance-status {
  color: #4caf50;
}

.insurance-info.invalid .insurance-status {
  color: #856404;
}

.insurance-period {
  font-size: 24rpx;
  color: #666;
}

/* 权限管理样式 */
.role-section {
  padding: 20rpx 0;
}

.role-display {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.role-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 15rpx;
}

.role-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: white;
  font-weight: bold;
}

.role-badge.admin {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.3);
}

.role-badge.user {
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.3);
}

.role-actions {
  display: flex;
  gap: 15rpx;
}

.role-btn {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  color: white;
  background: linear-gradient(135deg, #1296db 0%, #0d7ab8 100%);
}

.role-btn.disabled {
  background: #ccc;
  color: #999;
}

.insurance-info.temporary .insurance-status {
  color: #0288d1;
}

.insurance-period {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 5rpx;
}

/* 教练相关样式 */
.role-badge.teacher {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.role-badge.normal {
  background: linear-gradient(135deg, #9e9e9e 0%, #757575 100%);
  box-shadow: 0 2rpx 8rpx rgba(158, 158, 158, 0.3);
}

.role-btn.teacher-btn {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
}

.teacher-info {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #e8f5e9;
  border-radius: 12rpx;
  border-left: 4rpx solid #4caf50;
}

.info-hint {
  font-size: 26rpx;
  color: #2e7d32;
  line-height: 1.6;
}

/* 历史记录和教练课程列表样式 */
.history-scroll {
  max-height: 600rpx;
}

.history-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.history-item-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 15rpx;
}

.history-item-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-success {
  background-color: #e8f5e9;
  color: #4caf50;
}

.tag-pending {
  background-color: #fff3e0;
  color: #ff9800;
}

.tag-default {
  background-color: #f5f5f5;
  color: #999;
}

.tag-group {
  background-color: #e3f2fd;
  color: #1976d2;
}

.tag-private {
  background-color: #fce4ec;
  color: #e91e63;
}

.history-item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.history-item-status {
  margin-left: 15rpx;
}

.history-item-status.active {
  color: #4caf50;
}

.history-item-status.inactive {
  color: #999;
}

.empty-hint {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

.role-actions-three {
  display: flex;
  gap: 15rpx;
}

.role-btn-small {
  flex: 1;
  height: 70rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  color: white;
  background: linear-gradient(135deg, #1296db 0%, #0d7ab8 100%);
}

.role-btn-small.teacher-btn {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
}

.role-btn-small.admin-btn-color {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.role-btn-small.disabled {
  background: #ccc !important;
  color: #999 !important;
}

/* 会员卡区块 */
.membership-card-block {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 4rpx solid #ff9800;
}


.mc-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 10rpx;
}


.mc-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}


.mc-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background-color: #e3f2fd;
  color: #1976d2;
}


.mc-times {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}


.mc-times-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff9800;
}


.mc-status {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}


.mc-logs {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #e0e0e0;
}


.mc-logs-title {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 8rpx;
}


.mc-log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 22rpx;
  color: #999;
}


.mc-log-time { flex: 2; }
.mc-log-op { flex: 2; text-align: center; }
.mc-log-change { flex: 1; text-align: right; color: #ff5722; font-weight: bold; }

