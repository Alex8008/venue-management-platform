.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.header {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.participant-count {
  font-size: 26rpx;
  color: #666;
}

.participants-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.participant-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.participant-info {
  flex: 1;
  min-width: 0;
  margin-right: 15rpx;
}

.participant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.participant-phone {
  font-size: 26rpx;
  color: #666;
}

.participant-status {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.status-tag {
  background-color: #e8f5e8;
  color: #4caf50;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 10rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
  display: flex;
  gap: 20rpx;
}

.export-btn {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  color: white;
}

.export-btn.all {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.export-btn.no-insurance {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
  box-shadow: 0 4rpx 12rpx rgba(244, 67, 54, 0.3);
}