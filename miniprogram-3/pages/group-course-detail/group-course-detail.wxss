/* pages/group-course-detail/group-course-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 150rpx;
}

.course-cover {
  width: 100%;
  height: 400rpx;
}

.course-info-section {
  background-color: #fff;
  padding: 30rpx;
}

.course-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}



.meta-item {
  display: flex;
  margin-bottom: 15rpx;
  font-size: 28rpx;
}

.meta-label {
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.meta-value {
  color: #666;
  flex: 1;
}

.price-value {
  color: #FF7F50;
  font-size: 36rpx;
  font-weight: bold;
}

.teacher-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.teacher-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.teacher-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.teacher-intro {
  font-size: 26rpx;
  color: #999;
}

.view-detail-btn {
  color: #FF7F50;
  font-size: 26rpx;
}

.section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 15rpx 20rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: transparent;
  border: none;
  padding: 0;
  font-size: 20rpx;
  color: #666;
  line-height: 1.2;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 5rpx;
}

.action-btn .btn-text {
  font-size: 22rpx;
}

.enroll-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.price-show {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7F50;
}

.enroll-btn {
  background-color: #FF7F50;
  color: #fff;
  border-radius: 50rpx;
  border: none;
  font-size: 28rpx;
  padding: 18rpx 50rpx;
}

.enroll-btn-disabled {
  background-color: #ccc !important;
  color: #999 !important;
}
