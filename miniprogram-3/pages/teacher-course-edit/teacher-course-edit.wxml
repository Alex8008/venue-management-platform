<view class="container">
  <scroll-view class="content" scroll-y="true">

    <!-- 课程类型 -->
    <view class="section">
      <view class="section-title">课程类型</view>
      <view class="type-selector">
        <view class="type-option {{courseData.course_type === 'group' ? 'active' : ''}}"
              bindtap="onTypeSelect"
              data-type="group">
          <text class="type-icon">👥</text>
          <text class="type-text">团课</text>
        </view>
        <view class="type-option {{courseData.course_type === 'private' ? 'active' : ''}}"
              bindtap="onTypeSelect"
              data-type="private">
          <text class="type-icon">👤</text>
          <text class="type-text">私教</text>
        </view>
      </view>
    </view>

    <!-- 选择教练 -->
    <view class="section">
      <view class="section-title">选择教练 *</view>
      <view class="select-card-list">
        <view wx:for="{{teachers}}" wx:key="id"
              class="select-card-item {{item.selected ? 'selected' : ''}}"
              style="{{item.selected ? 'background:#e6f3ff;border:2rpx solid #1296db;color:#1296db;' : ''}}"
              data-index="{{index}}"
              bindtap="onTeacherToggle">
          {{item.name}}
        </view>
        <view wx:if="{{teachers.length === 0}}" class="placeholder-text">暂无可选教练</view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="form-label">课程标题 *</text>
        <input class="form-input"
               placeholder="请输入课程标题"
               value="{{courseData.title}}"
               data-field="title"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="form-label">课程封面</text>
        <image wx:if="{{courseData.cover_image}}"
               class="cover-preview"
               src="{{courseData.cover_image}}"
               mode="aspectFill"
               bindtap="onChooseCover" />
        <button class="upload-btn" bindtap="onChooseCover">
          {{courseData.cover_image ? '更换封面' : '上传封面'}}
        </button>
      </view>

      <view class="form-item">
        <text class="form-label">课程描述</text>
        <textarea class="form-textarea"
                  placeholder="请输入课程描述"
                  value="{{courseData.description}}"
                  data-field="description"
                  bindinput="onInputChange"
                  maxlength="500" />
      </view>

      <view class="form-item">
        <text class="form-label">筛选分类</text>
        <picker mode="selector"
                range="{{categories}}"
                range-key="category_name"
                value="{{selectedCategoryIndex}}"
                bindchange="onCategoryChange">
          <view class="picker-display">
            {{selectedCategory ? selectedCategory.category_name : '请选择分类'}}
          </view>
        </picker>
      </view>
    </view>

    <!-- 课程详情 -->
    <view class="section">
      <view class="section-title">课程详情</view>

      <view class="form-item">
        <text class="form-label">价格（元）*</text>
        <input class="form-input"
               type="digit"
               placeholder="请输入价格"
               value="{{courseData.price}}"
               data-field="price"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="form-label">课程时长（分钟）*</text>
        <input class="form-input"
               type="number"
               placeholder="请输入课程时长"
               value="{{courseData.duration}}"
               data-field="duration"
               bindinput="onInputChange" />
      </view>

      <view wx:if="{{courseData.course_type === 'group'}}" class="form-item">
        <text class="form-label">最大人数 *</text>
        <input class="form-input"
               type="number"
               placeholder="请输入最大人数"
               value="{{courseData.max_participants}}"
               data-field="max_participants"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="form-label">课程地点</text>
        <input class="form-input"
               placeholder="请输入课程地点"
               value="{{courseData.location}}"
               data-field="location"
               bindinput="onInputChange" />
      </view>
    </view>

    <!-- 时间设置 -->
    <view class="section">
      <view class="section-title">时间设置</view>

      <view class="form-item">
        <text class="form-label">报名开始时间</text>
        <picker mode="date"
                value="{{courseData.registration_start_date}}"
                data-field="registration_start"
                bindchange="onDateChange">
          <view class="picker">{{courseData.registration_start_date || '选择日期'}} {{courseData.registration_start_date ? courseData.registration_start_time || '00:00' : ''}}</view>
        </picker>
        <picker mode="time"
                value="{{courseData.registration_start_time}}"
                data-field="registration_start"
                bindchange="onTimeChange"
                class="time-picker">
          <view class="picker-small">选择时间</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">报名截止时间</text>
        <picker mode="date"
                value="{{courseData.registration_end_date}}"
                data-field="registration_end"
                bindchange="onDateChange">
          <view class="picker">{{courseData.registration_end_date || '选择日期'}} {{courseData.registration_end_date ? courseData.registration_end_time || '00:00' : ''}}</view>
        </picker>
        <picker mode="time"
                value="{{courseData.registration_end_time}}"
                data-field="registration_end"
                bindchange="onTimeChange"
                class="time-picker">
          <view class="picker-small">选择时间</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">课程开始时间</text>
        <picker mode="date"
                value="{{courseData.course_start_date}}"
                data-field="course_start"
                bindchange="onDateChange">
          <view class="picker">{{courseData.course_start_date || '选择日期'}} {{courseData.course_start_date ? courseData.course_start_time || '00:00' : ''}}</view>
        </picker>
        <picker mode="time"
                value="{{courseData.course_start_time}}"
                data-field="course_start"
                bindchange="onTimeChange"
                class="time-picker">
          <view class="picker-small">选择时间</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">课程结束时间</text>
        <picker mode="date"
                value="{{courseData.course_end_date}}"
                data-field="course_end"
                bindchange="onDateChange">
          <view class="picker">{{courseData.course_end_date || '选择日期'}} {{courseData.course_end_date ? courseData.course_end_time || '00:00' : ''}}</view>
        </picker>
        <picker mode="time"
                value="{{courseData.course_end_time}}"
                data-field="course_end"
                bindchange="onTimeChange"
                class="time-picker">
          <view class="picker-small">选择时间</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">取消限制时间</text>
        <picker mode="date"
                value="{{courseData.cancel_deadline_date}}"
                data-field="cancel_deadline"
                bindchange="onDateChange">
          <view class="picker">{{courseData.cancel_deadline_date || '选择日期'}} {{courseData.cancel_deadline_date ? courseData.cancel_deadline_time || '00:00' : ''}}</view>
        </picker>
        <picker mode="time"
                value="{{courseData.cancel_deadline_time}}"
                data-field="cancel_deadline"
                bindchange="onTimeChange"
                class="time-picker">
          <view class="picker-small">选择时间</view>
        </picker>
        <text class="field-tip">设置后，过了该时间用户将无法申请退款</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <view class="no-review-section">
        <view class="no-review-item" bindtap="onToggleNoReview">
          <view class="custom-checkbox {{courseData.no_review_needed ? 'checked' : ''}}">
            <text wx:if="{{courseData.no_review_needed}}">✓</text>
          </view>
          <text class="no-review-label">不需要审核（报名后直接付款即成功）</text>
        </view>
      </view>
      <button class="save-btn" bindtap="onSave">保存课程</button>
      <button wx:if="{{courseId}}" class="save-as-new-btn" bindtap="onSaveAsNew">保存为新课程</button>
    </view>
  </scroll-view>
</view>
