.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.address-section {
  background-color: #fff;
  padding: 25rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.address-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.address-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.address-detail {
  flex: 1;
  min-width: 0;
}

.receiver {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.address-text {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.no-address {
  flex: 1;
  color: #ff5722;
  font-size: 28rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  flex-shrink: 0;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.cart-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.cart-item .custom-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.cart-item .custom-checkbox.checked {
  background-color: #ff5722;
  border-color: #ff5722;
}

.cart-item .custom-checkbox .check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.item-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
  margin-right: 15rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 32rpx;
  color: #ff5722;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.item-quantity {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 50rpx;
  height: 50rpx;
  background-color: #f0f0f0;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  line-height: 50rpx;
  padding: 0;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-text {
  font-size: 28rpx;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}

.delete-btn {
  background-color: transparent;
  color: #f44336;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid #f44336;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.empty-cart {
  text-align: center;
  padding: 150rpx 20rpx;
}

.empty-cart text {
  display: block;
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.go-shop-btn {
  background-color: #1296db;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  border: none;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.select-all-wrapper {
  display: flex;
  align-items: center;
}

.select-all-wrapper .custom-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.select-all-wrapper .custom-checkbox.checked {
  background-color: #ff5722;
  border-color: #ff5722;
}

.select-all-wrapper .custom-checkbox .check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.select-all-label checkbox {
  margin-right: 10rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #333;
}

.total-info {
  flex: 1;
  text-align: right;
  margin: 0 20rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-price {
  font-size: 36rpx;
  color: #ff5722;
  font-weight: bold;
}

.checkout-btn {
  background-color: #ff5722;
  color: white;
  font-size: 28rpx;
  padding: 18rpx 40rpx;
  border-radius: 50rpx;
  border: none;
  flex-shrink: 0;
}

.delivery-teacher-tag {
  font-size: 22rpx;
  color: #ff9800;
  background-color: #fff3e0;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: inline-block;
}
