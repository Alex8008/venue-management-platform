.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.address-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.receiver-info {
  display: flex;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
  margin-right: 15rpx;
}

.receiver-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.receiver-phone {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.default-tag {
  background-color: #ff5722;
  color: white;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 15rpx;
}

.address-detail text {
  display: block;
}

.address-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 15rpx;
  border-radius: 8rpx;
  border: 1rpx solid #1296db;
  color: #1296db;
  background-color: #fff;
}

.action-btn.delete {
  border-color: #f44336;
  color: #f44336;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.add-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1296db 0%, #0d7ab8 100%);
  color: white;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}