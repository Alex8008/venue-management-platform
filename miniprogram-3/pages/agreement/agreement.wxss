.container {
  padding: 30rpx;
  background: #fff;
  min-height: 100vh;
}


.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 10rpx;
  color: #333;
}


.update-time {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}


.section {
  margin-bottom: 30rpx;
}


.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}


.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
