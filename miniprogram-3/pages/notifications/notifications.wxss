.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.content {
  padding: 20rpx;
  box-sizing: border-box;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.notification-card {
  position: relative;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  padding-left: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  border-left: 4rpx solid #1296db;
}

.notification-card.unread {
  background-color: #f8f9ff;
}

.notification-card.read {
  background-color: #fff;
  opacity: 0.85;
}

.notification-card.failed {
  border-left-color: #f44336;
}

/* 未读红点 */
.unread-dot {
  position: absolute;
  top: 30rpx;
  left: 15rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff5722;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(255, 87, 34, 0.6);
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.notification-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 10rpx;
}

.notification-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.notification-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 15rpx;
}

.notification-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.notification-type {
  font-size: 24rpx;
  color: #1296db;
  background-color: #e3f2fd;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  height: 48rpx;
  line-height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.notification-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  height: 48rpx;
  min-width: 80rpx;
  line-height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.notification-status.unread {
  background-color: #fff3e0;
  color: #ff9800;
  font-weight: bold;
}

.notification-status.read {
  background-color: #e8f5e9;
  color: #4caf50;
}

.notification-status.failed {
  background-color: #ffebee;
  color: #f44336;
}

.empty-notifications {
  text-align: center;
  padding: 150rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}
