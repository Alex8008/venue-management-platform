.container { min-height: 100vh; background-color: #f8f8f8; display: flex; flex-direction: column; padding-bottom: 150rpx; }
.header { background-color: #1296db; padding: 30rpx; text-align: center; }
.title { font-size: 36rpx; font-weight: bold; color: #fff; }
.content { flex: 1; padding: 20rpx; }
.category-item { background-color: #fff; border-radius: 12rpx; margin-bottom: 15rpx; padding: 25rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.category-info { flex: 1; }
.category-name { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.category-order { font-size: 24rpx; color: #999; }
.category-actions { display: flex; gap: 10rpx; }
.edit-btn, .delete-btn { padding: 10rpx 20rpx; border-radius: 8rpx; font-size: 22rpx; border: none; }
.edit-btn { background-color: #2196f3; color: #fff; }
.delete-btn { background-color: #ff5722; color: #fff; }
.empty, .loading { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background-color: #fff; padding: 20rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); }
.create-btn { width: 100%; background-color: #1296db; color: #fff; font-size: 32rpx; padding: 25rpx; border-radius: 12rpx; border: none; }
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.modal-content { width: 600rpx; background-color: #fff; border-radius: 20rpx; overflow: hidden; }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.modal-title { font-size: 36rpx; font-weight: bold; color: #333; }
.modal-close { font-size: 60rpx; color: #999; line-height: 1; }
.modal-body { padding: 30rpx; }
.form-item { margin-bottom: 30rpx; }
.form-label { font-size: 28rpx; color: #666; display: block; margin-bottom: 15rpx; }
.form-input { width: 100%; height: 80rpx; padding: 0 20rpx; border: 2rpx solid #e0e0e0; border-radius: 8rpx; font-size: 28rpx; background-color: #f8f8f8; box-sizing: border-box; }
.modal-actions { display: flex; border-top: 1rpx solid #f0f0f0; }
.cancel-btn, .confirm-btn { flex: 1; padding: 30rpx; font-size: 32rpx; border: none; background-color: transparent; }
.cancel-btn { color: #999; border-right: 1rpx solid #f0f0f0; }
.confirm-btn { color: #1296db; font-weight: bold; }
