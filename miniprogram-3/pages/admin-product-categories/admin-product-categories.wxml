<view class="container">
  <view class="header">
    <text class="title">商品分类管理</text>
  </view>

  <scroll-view class="content" scroll-y="true">
    <view class="category-item" wx:for="{{categories}}" wx:key="id">
      <view class="category-info">
        <view class="category-name">{{item.category_name}}</view>
        <view class="category-order">排序：{{item.sort_order}}</view>
      </view>
      <view class="category-actions">
        <button class="edit-btn" bindtap="onEdit" data-id="{{item.id}}">编辑</button>
        <button class="delete-btn" bindtap="onDelete" data-id="{{item.id}}">删除</button>
      </view>
    </view>

    <view wx:if="{{categories.length === 0 && !loading}}" class="empty">
      <text>暂无分类</text>
    </view>
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="create-btn" bindtap="onAdd">+ 新建分类</button>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-overlay" wx:if="{{showModal}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{editId ? '编辑分类' : '新建分类'}}</text>
        <text class="modal-close" bindtap="onCloseModal">x</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">分类名称 *</text>
          <input class="form-input" placeholder="请输入分类名称"
                 value="{{formData.category_name}}" bindinput="onNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">排序</text>
          <input class="form-input" type="number" placeholder="数字越小越靠前"
                 value="{{formData.sort_order}}" bindinput="onOrderInput" />
        </view>
      </view>
      <view class="modal-actions">
        <button class="cancel-btn" bindtap="onCloseModal">取消</button>
        <button class="confirm-btn" bindtap="onConfirm">确定</button>
      </view>
    </view>
  </view>
</view>
