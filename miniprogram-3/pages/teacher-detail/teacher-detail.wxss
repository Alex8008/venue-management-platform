/* pages/teacher-detail/teacher-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 20rpx;
}

/* 教练封面 */
.teacher-cover {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.teacher-header {
  display: flex;
  align-items: center;
}

.teacher-avatar-small {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-right: 20rpx;
}

.teacher-name-box {
  display: flex;
  flex-direction: column;
}

.teacher-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.teacher-lessons {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.collect-btn {
  background-color: #FF7F50;
  color: #fff;
  padding: 15rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 分区 */
.section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 私教课程列表 */
.course-list {
}

.course-item {
  display: flex;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.course-image {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.course-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.course-meta {
  font-size: 24rpx;
  color: #999;
}

.course-duration {
}

.course-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7F50;
}

/* 日期选择 */
.date-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.date-list {
  display: inline-flex;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 25rpx;
  margin-right: 10rpx;
  border-radius: 12rpx;
  background-color: #f8f8f8;
  transition: all 0.3s;
}

.date-item.active {
  background-color: #FF7F50;
  color: #fff;
}

.date-num {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.date-week {
  font-size: 24rpx;
}

/* 团课列表 */
.group-course-list {
}

.group-course-item {
  display: flex;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.group-course-image {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.group-course-info {
  flex: 1;
  padding: 20rpx;
}

.group-course-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.group-course-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.group-course-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7F50;
}

/* 空提示 */
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}
