<view class="container">
  <scroll-view scroll-y="true" class="content">
    
    <view class="section">
      <view class="form-item">
        <text class="label">收货人 *</text>
        <input class="input" 
               placeholder="请输入收货人姓名"
               value="{{address.receiver_name}}"
               data-field="receiver_name"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="label">手机号 *</text>
        <input class="input" 
               type="number"
               placeholder="请输入手机号"
               value="{{address.receiver_phone}}"
               data-field="receiver_phone"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="label">所在地区 *</text>
        <picker mode="region" 
                value="{{regionValue}}"
                bindchange="onRegionChange">
          <view class="region-picker">
            <text wx:if="{{address.province}}">
              {{address.province}} {{address.city}} {{address.district}}
            </text>
            <text wx:else class="placeholder">请选择省市区</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">详细地址 *</text>
        <textarea class="textarea" 
                  placeholder="请输入详细地址，如街道、门牌号等"
                  value="{{address.detail_address}}"
                  data-field="detail_address"
                  bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <checkbox-group bindchange="onDefaultChange">
          <label class="checkbox-label">
            <checkbox value="default" checked="{{address.is_default}}" />
            <text>设为默认地址</text>
          </label>
        </checkbox-group>
      </view>
    </view>

  </scroll-view>

  <view class="bottom-bar">
    <button class="save-btn" bindtap="onSave">
      保存地址
    </button>
  </view>
</view>