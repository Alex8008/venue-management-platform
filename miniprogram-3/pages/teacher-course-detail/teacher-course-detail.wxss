/* pages/teacher-course-detail/teacher-course-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 150rpx;
}

.course-cover {
  width: 100%;
  height: 400rpx;
}

.course-info-box {
  background-color: #fff;
  padding: 30rpx;
}

.course-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.course-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9800;
  margin-bottom: 10rpx;
}

.price-unit {
  font-size: 28rpx;
  color: #999;
}

.course-meta {
  font-size: 28rpx;
  color: #666;
}

.time-select-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.date-scroll {
  white-space: nowrap;
  margin-bottom: 30rpx;
}

.date-list {
  display: inline-flex;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 25rpx;
  margin-right: 15rpx;
  border-radius: 12rpx;
  background-color: #f8f8f8;
}

.date-item.active {
  background-color: #ff9800;
  color: #fff;
}

.date-num {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.date-week {
  font-size: 24rpx;
}

.time-slot-box {
}

.hint-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  display: block;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-slot {
  padding: 20rpx 40rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.time-slot.selected {
  background-color: #ff9800;
  color: #fff;
}

.time-slot.disabled {
  background-color: #e0e0e0;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 15rpx 20rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: transparent;
  border: none;
  padding: 0;
  font-size: 20rpx;
  color: #666;
  line-height: 1.2;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 5rpx;
}

.action-btn .btn-text {
  font-size: 22rpx;
}

.purchase-area {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.btn-primary {
  background-color: #ff9800;
  color: #fff;
  border-radius: 50rpx;
  font-size: 26rpx;
  padding: 16rpx 30rpx;
  border: none;
}

.btn-secondary {
  background-color: #fff;
  color: #ff9800;
  border: 2rpx solid #ff9800;
  border-radius: 50rpx;
  font-size: 26rpx;
  padding: 16rpx 30rpx;
}

.notice-box {
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ff9800;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}
