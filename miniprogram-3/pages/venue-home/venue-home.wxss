/* pages/venue-home/venue-home.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 橙色头部装饰条 */
.page-header {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  padding: 20rpx 30rpx;
  text-align: center;
}

.page-header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 轮播图区域 */
.carousel-section {
  width: 100%;
  background-color: #fff;
}

.carousel {
  width: 100%;
  height: 400rpx;
}

.carousel-image {
  width: 100%;
  height: 100%;
}

/* 内容区域 */
.content-section {
  padding: 20rpx 30rpx;
}

/* 横幅图片 */
.banner-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  display: block;
}

.banner-title {
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 文字内容 */
.text-item {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
}

.text-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.text-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 活动推荐 */
.activity-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.activity-image {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  padding: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.activity-desc {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
