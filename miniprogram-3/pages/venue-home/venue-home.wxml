<!--pages/venue-home/venue-home.wxml-->
<view class="container">
  <!-- 轮播图 -->
  <view class="carousel-section">
    <swiper class="carousel" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}" circular="{{true}}">
      <block wx:for="{{carouselList}}" wx:key="id">
        <swiper-item>
          <image src="{{item.image_url}}" class="carousel-image" mode="aspectFill" bindtap="onCarouselTap" data-item="{{item}}"></image>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <!-- 内容区域 -->
  <view class="content-section">
    <block wx:for="{{contentList}}" wx:key="id">
      <!-- 横幅图片 -->
      <view wx:if="{{item.content_type === 'banner'}}" class="banner-item" bindtap="onContentTap" data-item="{{item}}">
        <image src="{{item.image_url}}" class="banner-image" mode="widthFix"></image>
        <view wx:if="{{item.title}}" class="banner-title">{{item.title}}</view>
      </view>

      <!-- 文字内容 -->
      <view wx:elif="{{item.content_type === 'text'}}" class="text-item">
        <view class="text-title">{{item.title}}</view>
        <view class="text-content">{{item.content}}</view>
      </view>

      <!-- 活动推荐 -->
      <view wx:elif="{{item.content_type === 'activity'}}" class="activity-item" bindtap="onContentTap" data-item="{{item}}">
        <image src="{{item.image_url}}" class="activity-image" mode="aspectFill"></image>
        <view class="activity-info">
          <view class="activity-title">{{item.title}}</view>
          <view wx:if="{{item.content}}" class="activity-desc">{{item.content}}</view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{contentList.length === 0}}" class="empty-state">
      <text class="empty-text">暂无内容</text>
    </view>
  </view>
</view>
