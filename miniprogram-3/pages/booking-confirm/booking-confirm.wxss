.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 150rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.content {
  padding: 20rpx;
}

.section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.info-card {
  display: flex;
  gap: 20rpx;
}

.course-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.course-teacher,
.course-type {
  font-size: 26rpx;
  color: #666;
}

.time-info {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-label {
  font-size: 28rpx;
  color: #666;
}

.time-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.pay-options {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.pay-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
}

.pay-option.active {
  border-color: #1296db;
  background-color: #e3f2fd;
}

.pay-option.disabled {
  opacity: 0.5;
}

.pay-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.pay-desc {
  font-size: 24rpx;
  color: #999;
}

.fee-detail {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-label {
  font-size: 28rpx;
  color: #666;
}

.fee-value {
  font-size: 28rpx;
  color: #333;
}

.fee-row.discount .fee-value {
  color: #4caf50;
}

.fee-row.total {
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 5rpx;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff5722;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.price-display {
  display: flex;
  align-items: baseline;
}

.pay-label {
  font-size: 26rpx;
  color: #666;
}

.pay-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff5722;
}

.confirm-btn {
  background-color: #1296db;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border-radius: 12rpx;
  border: none;
}
