.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.section {
  background-color: #fff;
  margin: 0 0 20rpx 0;
  border-radius: 12rpx;
  padding: 30rpx 25rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.activity-card {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
}

.activity-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  min-width: 0;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-time, .activity-location {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 5rpx;
}

/* 统一信息行样式 */
.info-row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.info-label {
  width: 180rpx;
  color: #666;
  flex-shrink: 0;
  white-space: nowrap;
}

.info-value {
  flex: 1;
  color: #333;
  word-wrap: break-word;
  word-break: break-word;
  min-width: 0;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fee-row.required {
  background-color: #f8f9fa;
  padding: 20rpx 15rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  border-bottom: none;
}

.fee-info {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.fee-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.fee-checkbox {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.fee-checkbox checkbox {
  margin-right: 10rpx;
  flex-shrink: 0;
}

.checkbox-text {
  flex: 1;
}

.fee-amount {
  font-size: 30rpx;
  color: #ff5722;
  font-weight: bold;
  flex-shrink: 0;
  min-width: 130rpx;
  text-align: right;
  align-self: center;
}

.fee-amount.disabled {
  color: #999;
  text-decoration: line-through;
}

.total-fee {
  margin-top: 20rpx;
  padding: 25rpx 20rpx;
  border-top: 2rpx solid #1296db;
  background-color: #e3f2fd;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.total-label {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.total-amount {
  font-size: 44rpx;
  color: #ff5722;
  font-weight: bold;
}

.requirements {
  background-color: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.agreement {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.agreement checkbox {
  margin-right: 15rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.price-info {
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 36rpx;
  color: #ff5722;
  font-weight: bold;
  margin-left: 10rpx;
}

.submit-btn {
  background-color: #1296db;
  color: white;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  border: none;
}

.submit-btn.disabled {
  background-color: #ccc;
  color: #999;
}
