/* 备份相关样式 */
.backup-info {
  background-color: #e3f2fd;
  padding: 25rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.info-text {
  display: block;
  font-size: 26rpx;
  color: #1976d2;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.backup-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: white;
  font-size: 32rpx;
  padding: 25rpx;
  border-radius: 12rpx;
  border: none;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.backup-tips {
  background-color: #fff3cd;
  padding: 20rpx;
  border-radius: 12rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #856404;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.backup-tips text {
  display: block;
  font-size: 24rpx;
  color: #856404;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

/* 管理页面相关样式 */
.management-info {
  background-color: #e8f5e9;
  padding: 25rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.manage-btn {
  width: 100%;
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
  color: white;
  font-size: 32rpx;
  padding: 25rpx;
  border-radius: 12rpx;
  border: none;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.management-tips {
  background-color: #fff8e1;
  padding: 20rpx;
  border-radius: 12rpx;
}

.management-tips text {
  display: block;
  font-size: 24rpx;
  color: #f57f17;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

/* 赠送弹窗样式 */
.gift-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.gift-modal {
  width: 92%;
  max-height: 85vh;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.gift-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.gift-modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.gift-modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.gift-search-bar {
  padding: 16rpx 24rpx;
}

.gift-search-input {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 72rpx;
  line-height: 1.5;
}


.gift-select-all {
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: #1296db;
}

.gift-user-list {
  max-height: 60vh;
  padding: 0 24rpx;
}

.gift-user-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: #f9f9f9;
  transition: all 0.2s;
}

.gift-user-item.selected {
  background: #e6f3ff;
  border: 2rpx solid #1296db;
}

.gift-user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.gift-user-info {
  display: flex;
  flex-direction: column;
}

.gift-user-name {
  font-size: 28rpx;
  color: #333;
}

.gift-user-type {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.gift-confirm-btn {
  margin: 20rpx 24rpx;
  background: #1296db;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}
