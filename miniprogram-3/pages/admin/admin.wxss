.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.tab-bar {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #e0e0e0;
}

.tab-scroll {
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  flex: none;
  min-width: 160rpx;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #1296db;
  border-bottom-color: #1296db;
  font-weight: bold;
}

.content {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.tab-content {
  min-height: 100%;
  padding-bottom: 150rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 28rpx;
  background-color: #f8f9fa;
}

.search-btn {
  margin-left: 15rpx;
  padding: 12rpx 30rpx;
  background-color: #1296db;
  color: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

/* 视图切换按钮 */
.view-toggle {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid #1296db;
}

.toggle-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #1296db;
}

.toggle-item.active {
  background-color: #1296db;
  color: #fff;
}

.course-booking-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.batch-select {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  box-sizing: border-box;
}

.select-all-wrapper {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 28rpx;
  color: #333;
}

.custom-checkbox {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  min-height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  background-color: #fff;
  transition: all 0.2s;
}

.custom-checkbox.checked {
  background-color: #1296db;
  border-color: #1296db;
}

.check-icon {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  line-height: 1;
}

.batch-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.batch-actions-inner {
  display: flex;
  gap: 20rpx;
}

.batch-approve-btn, .batch-reject-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.batch-approve-btn {
  background-color: #4caf50;
  color: white;
}

.batch-reject-btn {
  background-color: #f44336;
  color: white;
}

.select-mode-btn {
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  background-color: #1296db;
  color: white;
  width: 200rpx;
}

.cancel-btn {
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid #999;
  background-color: #fff;
  color: #666;
  width: 150rpx;
  flex-shrink: 0;
}

.batch-select-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.select-all-text-btn {
  display: inline-block;
  padding: 10rpx 30rpx;
  font-size: 28rpx;
  color: #1296db;
  border: 2rpx solid #1296db;
  border-radius: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1296db;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.create-btn {
  background-color: #4caf50;
  color: white;
  font-size: 26rpx;
  padding: 15rpx 30rpx;
  border-radius: 25rpx;
  border: none;
}

.activity-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  display: flex;
  min-height: 200rpx;
  box-sizing: border-box;
}

.activity-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-meta {
  display: flex;
  gap: 15rpx;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.category {
  background-color: #e3f2fd;
  color: #1976d2;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.participants {
  color: #666;
}

.status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: white;
}

.status.published {
  background-color: #4caf50;
}

.status.draft {
  background-color: #ff9800;
}

.status.closed {
  background-color: #9e9e9e;
}

.status.active {
  background-color: #4caf50;
}

.status.inactive {
  background-color: #f44336;
}

.activity-date {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-fee {
  font-size: 28rpx;
  color: #ff5722;
  font-weight: bold;
}

.activity-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  margin-left: 15rpx;
  flex-shrink: 0;
}

.activity-actions .action-btn {
  width: 120rpx;
  height: 60rpx;
  font-size: 24rpx;
  padding: 0;
  margin: 0;
  text-align: center;
  line-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-actions .edit {
  background-color: #2196f3;
  color: white;
}

.activity-actions .participants {
  background-color: #9c27b0;
  color: white;
}

.activity-actions .delete {
  background-color: #f44336;
  color: white;
}

.registration-card {
