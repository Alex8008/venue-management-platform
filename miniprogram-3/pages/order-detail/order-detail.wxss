.container { min-height: 100vh; background: #f5f5f5; }
.content { padding: 20rpx; }

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
  font-size: 28rpx;
}

.info-label { color: #666; }
.info-value { color: #333; font-weight: 500; }
.status-text { color: #1296db; }
.price-text { color: #ff5722; font-weight: bold; }

.product-card {
  display: flex;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-card:last-child { border-bottom: none; }

.product-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 28rpx; color: #333; font-weight: bold; }

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price { font-size: 28rpx; color: #ff5722; font-weight: bold; }
.product-qty { font-size: 26rpx; color: #999; }

.refund-status-text { color: #ff9800; }

.action-section {
  padding: 30rpx 0;
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.pay-btn {
  background: #1296db;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.refund-btn {
  background: #fff;
  color: #ff5722;
  font-size: 30rpx;
  border: 2rpx solid #ff5722;
  border-radius: 8rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
}
