.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.top-bar {
  background-color: #1296db;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 32rpx;
  color: white;
  font-weight: bold;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-btn {
  background-color: transparent;
  color: white;
  font-size: 28rpx;
  padding: 10rpx 25rpx;
  border: 1rpx solid white;
  border-radius: 20rpx;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.photo-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  background-color: #fff;
  border-radius: 8rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.photo-item.selected {
  border-color: #1296db;
  border-width: 6rpx;
}


.photo-thumbnail {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 选中遮罩层（整体变色 + 对勾） */
.selected-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(18, 150, 219, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}


.selected-check {
  width: 60rpx;
  height: 60rpx;
  background-color: #1296db;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(18, 150, 219, 0.5);
}

.empty-photos {
  text-align: center;
  padding: 150rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.selected-count {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.button-group {
  display: flex;
  gap: 15rpx;
  flex: 2;
}

.upload-btn, .download-btn, .delete-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  color: white;
}

.upload-btn {
  background: linear-gradient(135deg, #1296db 0%, #0d7ab8 100%);
}

.download-btn {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
}

.delete-btn {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
}
