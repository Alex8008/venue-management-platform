.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 150rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.product-header {
  width: 100%;
  height: 600rpx;
  background-color: #fff;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.product-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.product-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff5722;
}

.product-stock {
  font-size: 26rpx;
  color: #999;
}

.product-category {
  margin-top: 10rpx;
}

.category-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #1296db;
  background-color: #e3f2fd;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.product-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 15rpx 20rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: transparent;
  border: none;
  padding: 0;
  font-size: 20rpx;
  color: #666;
  line-height: 1.2;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 5rpx;
}

.action-btn .btn-text {
  font-size: 22rpx;
}

.purchase-area {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.cart-icon {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 50%;
  flex-shrink: 0;
}

.icon-text {
  font-size: 32rpx;
}


.cart-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  background-color: #ff5722;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 6rpx;
}

.add-cart-btn {
  flex: 1;
  background-color: #ff9800;
  color: #fff;
  font-size: 26rpx;
  padding: 18rpx 10rpx;
  border-radius: 50rpx;
  border: none;
  white-space: nowrap;
  line-height: 1.2;
}

.buy-btn {
  flex: 1;
  background-color: #ff5722;
  color: #fff;
  font-size: 26rpx;
  padding: 18rpx 10rpx;
  border-radius: 50rpx;
  border: none;
  white-space: nowrap;
  line-height: 1.2;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
