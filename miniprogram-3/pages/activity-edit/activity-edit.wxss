.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  border-left: 4rpx solid #1296db;
  padding-left: 15rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 70rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f8f9fa;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f8f9fa;
  box-sizing: border-box;
}

.picker {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #f8f9fa;
}

/* 多图片上传样式 */
.image-upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.delete-icon {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 40rpx;
  line-height: 50rpx;
  text-align: center;
  border-radius: 50%;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f8f9fa;
}

.add-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

/* 地图选点样式 */
.location-input-group {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.location-input {
  flex: 1;
}

.map-btn {
  width: 180rpx;
  height: 70rpx;
  background-color: #1296db;
  color: white;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-info {
  margin-top: 15rpx;
  padding: 15rpx;
  background-color: #e3f2fd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-tip {
  font-size: 26rpx;
  color: #1976d2;
}

.location-coords {
  font-size: 22rpx;
  color: #666;
}

.field-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  line-height: 1.5;
}

.checkbox-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 25rpx;
}

.checkbox-label checkbox {
  margin-right: 15rpx;
}

/* 底部按钮区域 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 15rpx 30rpx;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.no-review-section {
  width: 100%;
  margin-bottom: 5rpx;
}

.no-review-item {
  display: flex;
  align-items: center;
}

.no-review-item .custom-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.no-review-item .custom-checkbox.checked {
  background-color: #1296db;
  border-color: #1296db;
}

.no-review-label {
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
  color: white;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.save-as-new-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  color: white;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.total-fee-display {
  background-color: #e3f2fd;
  padding: 20rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.total-label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.total-amount {
  font-size: 40rpx;
  color: #ff5722;
  font-weight: bold;
}

.time-picker {
  margin-top: 10rpx;
}

.picker-small {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  background-color: #f8f9fa;
  text-align: center;
  color: #1296db;
}