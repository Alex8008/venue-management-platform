.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.course-header {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.course-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.course-meta-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex-wrap: wrap;
}

.course-type-tag {
  background-color: #e3f2fd;
  color: #1976d2;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.participant-count {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;
}

.max-count {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.participant-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.participant-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.participant-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #eee;
}

.participant-info {
  flex: 1;
  min-width: 0;
}

.participant-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.participant-detail {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.participant-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.participant-fee {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 24rpx;
  color: #666;
}

.payment-status {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}

.payment-status.paid {
  background-color: #e8f5e9;
  color: #4caf50;
}

.payment-status.unpaid {
  background-color: #fff3e0;
  color: #ff9800;
}

.participant-status {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
}

.status-approved  { background-color: #e8f5e9; color: #4caf50; }
.status-pending   { background-color: #fff3e0; color: #ff9800; }
.status-rejected  { background-color: #ffebee; color: #f44336; }
.status-completed { background-color: #e3f2fd; color: #1976d2; }
.status-cancelled { background-color: #f5f5f5; color: #999; }

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.empty-state {
  text-align: center;
  padding: 120rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon { font-size: 100rpx; }
.empty-text { font-size: 28rpx; color: #999; }
