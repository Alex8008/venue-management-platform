.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
  border-bottom: none;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  border: none;
  border-radius: 35rpx;
  font-size: 28rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.search-btn {
  margin-left: 20rpx;
  padding: 15rpx 30rpx;
  background-color: #fff;
  color: #ff9800;
  border-radius: 35rpx;
  font-size: 28rpx;
  border: none;
  font-weight: bold;
}

.address-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 100rpx;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.address-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.address-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.receiver {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.address {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.no-address {
  flex: 1;
  display: flex;
  align-items: center;
  color: #1296db;
  font-size: 28rpx;
}

.add-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 主内容区布局 */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  background-color: #f8f8f8;
  border-right: 1rpx solid #e0e0e0;
  flex-shrink: 0;
}

.category-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #e0e0e0;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #fff;
  color: #1296db;
  font-weight: bold;
  border-left: 6rpx solid #1296db;
}

/* 右侧内容区 */
.content {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0;
}

.product-item {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.product-image {
  width: 100%;
  height: 300rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 32rpx;
  color: #ff5722;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.product-stock {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.add-cart-btn {
  width: 100%;
  background-color: #1296db;
  color: white;
  font-size: 26rpx;
  padding: 15rpx;
  border-radius: 25rpx;
  border: none;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
  grid-column: 1 / -1;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.cart-info {
  display: flex;
  align-items: center;
}

.cart-icon {
  position: relative;
  font-size: 40rpx;
  margin-right: 15rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ff5722;
  color: white;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-text {
  font-size: 28rpx;
  color: #333;
}

.order-btn {
  background-color: #ff5722;
  color: white;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  border: none;
}

/* 教练选择弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}

.teacher-list {
  flex: 1;
  padding: 20rpx;
}

.teacher-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.teacher-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.teacher-intro {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-icon {
  font-size: 40rpx;
  color: #1296db;
  margin-left: 20rpx;
}

.modal-empty {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
