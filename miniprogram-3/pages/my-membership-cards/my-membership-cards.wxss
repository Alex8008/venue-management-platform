.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
  padding-bottom: 150rpx;
}

.content {
  flex: 1;
  padding: 20rpx;
}

/* 卡片 */
.card-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  padding: 20rpx;
  box-sizing: border-box;
}

.card-expired {
  opacity: 0.5;
}

.card-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gift-tag {
  display: inline-block;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.card-teacher {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

/* 次卡次数 */
.card-times {
  margin-bottom: 8rpx;
}

.times-remaining {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7F50;
}

.times-total {
  font-size: 24rpx;
  color: #999;
}

/* 状态徽章 */
.card-status-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.status-active   { background-color: #e8f5e9; color: #4caf50; }
.status-inactive { background-color: #fff3e0; color: #ff9800; }
.status-expired  { background-color: #e0e0e0; color: #9e9e9e; }

.card-detail-row {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
  margin-left: 15rpx;
  flex-shrink: 0;
}

.activate-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
  background-color: #FF7F50;
  color: #fff;
}

.detail-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
  background-color: #f0f0f0;
  color: #666;
}

/* 加载/空状态 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 0 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
}

/* ★ 底部购买按钮 — 始终显示 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.buy-card-btn {
  width: 100%;
  background-color: #FF7F50;
  color: #fff;
  font-size: 32rpx;
  padding: 25rpx;
  border-radius: 12rpx;
  border: none;
}
