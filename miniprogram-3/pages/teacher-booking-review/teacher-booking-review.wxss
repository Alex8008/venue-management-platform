.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* 视图切换按钮 */
.view-toggle {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid #1296db;
}

.toggle-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #1296db;
}

.toggle-item.active {
  background-color: #1296db;
  color: #fff;
}

.course-booking-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.batch-select-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.select-all-text-btn {
  display: inline-block;
  padding: 10rpx 30rpx;
  font-size: 28rpx;
  color: #1296db;
  border: 2rpx solid #1296db;
  border-radius: 8rpx;
}

.registration-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  transition: background-color 0.2s;
  border-left: 6rpx solid transparent;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.registration-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  margin-right: 10rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
}

.registration-date {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.activity-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.activity-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  margin-right: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-fee {
  font-size: 28rpx;
  color: #ff5722;
  font-weight: bold;
  flex-shrink: 0;
}

.batch-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.batch-actions-inner {
  display: flex;
  gap: 20rpx;
}

.batch-approve-btn, .batch-reject-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.batch-approve-btn {
  background-color: #4caf50;
  color: white;
}

.batch-reject-btn {
  background-color: #f44336;
  color: white;
}

.select-mode-btn {
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  background-color: #1296db;
  color: white;
  width: 200rpx;
}

.cancel-btn {
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid #999;
  background-color: #fff;
  color: #666;
  width: 150rpx;
  flex-shrink: 0;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999;
}

.empty-state text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}
