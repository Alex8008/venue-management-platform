/* pages/private-booking/private-booking.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 20rpx;
}

/* 顶部选项卡 */
.tab-bar {
  display: flex;
  background-color: #FF7F50;
  padding: 20rpx 40rpx;
  justify-content: center;
}

.tab-item {
  padding: 15rpx 50rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 50rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #fff;
  color: #FF7F50;
  font-weight: bold;
}

/* 日期选择条 */
.date-scroll {
  background-color: #FF7F50;
  white-space: nowrap;
  padding: 20rpx 0;
}

.date-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 25rpx;
  margin: 0 10rpx;
  border-radius: 12rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s;
}

.date-item.active {
  background-color: #fff;
  color: #FF7F50;
}

.date-num {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.date-week {
  font-size: 24rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.search-input {
  background-color: #f8f8f8;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

/* 教练列表 */
.teacher-list {
  padding: 0 30rpx;
}

.teacher-item {
  display: flex;
  align-items: center;
  background-color: #333;
  color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.teacher-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid #fff;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.teacher-stats {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.action-btn {
  background-color: #FF7F50;
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载提示 */
.loading {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
