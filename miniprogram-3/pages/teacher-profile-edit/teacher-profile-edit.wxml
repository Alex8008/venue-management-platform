<view class="container">
  <scroll-view class="content" scroll-y="true">


    <!-- 头像封面 -->
    <view class="section">
      <view class="section-title">头像和封面</view>

      <view class="avatar-section">
        <text class="field-label">头像</text>
        <image class="avatar-preview"
               src="{{teacherInfo.avatar_url || '/images/default-avatar.png'}}"
               mode="aspectFill"
               bindtap="onChooseAvatar" />
        <button class="upload-btn" bindtap="onChooseAvatar">选择头像</button>
      </view>

      <view class="cover-section">
        <text class="field-label">封面图</text>
        <image class="cover-preview"
               src="{{teacherInfo.teacher_cover_image || '/images/default-cover.png'}}"
               mode="aspectFill"
               bindtap="onChooseCover" />
        <button class="upload-btn" bindtap="onChooseCover">选择封面</button>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="form-label">真实姓名</text>
        <input class="form-input"
               placeholder="请输入真实姓名"
               value="{{teacherInfo.real_name}}"
               data-field="real_name"
               bindinput="onInputChange" />
      </view>

      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input"
               placeholder="请输入手机号"
               value="{{teacherInfo.phone}}"
               data-field="phone"
               bindinput="onInputChange" />
      </view>
    </view>

    <!-- 教练信息 -->
    <view class="section">
      <view class="section-title">教练信息</view>

      <view class="form-item">
        <text class="form-label">教练简介</text>
        <textarea class="form-textarea"
                  placeholder="请输入教练简介（一句话介绍）"
                  value="{{teacherInfo.teacher_intro}}"
                  data-field="teacher_intro"
                  bindinput="onInputChange"
                  maxlength="100" />
      </view>

      <view class="form-item">
        <text class="form-label">详细介绍</text>
        <textarea class="form-textarea large"
                  placeholder="请输入详细介绍（资质、经历、擅长等）"
                  value="{{teacherInfo.teacher_detail}}"
                  data-field="teacher_detail"
                  bindinput="onInputChange"
                  maxlength="1000" />
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="actions">
      <button class="save-btn" bindtap="onSave">保存修改</button>
    </view>
  </scroll-view>
</view>
