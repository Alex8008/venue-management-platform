.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.content {
  padding: 20rpx;
  box-sizing: border-box;
}

.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 15rpx;
}

.order-status {
  font-size: 26rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.order-status.pending  { background-color: #fff3e0; color: #ff9800; }
.order-status.paid     { background-color: #e8f5e9; color: #4caf50; }
.order-status.cancelled{ background-color: #f5f5f5; color: #999; }
.order-status.refunded { background-color: #e3f2fd; color: #1976d2; }
.order-status.completed{ background-color: #e8f5e9; color: #4caf50; }

/* 商品列表 */
.order-items {
  margin-bottom: 15rpx;
}

.order-item {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 26rpx;
  color: #666;
}

/* 订单总价 */
.order-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff5722;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 15rpx;
}

.cancel-btn {
  font-size: 26rpx;
  color: #999;
  background-color: #f5f5f5;
  border: none;
  padding: 14rpx 30rpx;
  border-radius: 30rpx;
}

.pay-btn {
  font-size: 26rpx;
  color: #fff;
  background-color: #ff5722;
  border: none;
  padding: 14rpx 40rpx;
  border-radius: 30rpx;
}

.cancelled-tip {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-orders {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}
